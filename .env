APP_ENV=production

# Telegram 机器人 Token
TG_BOT_TOKEN=你的机器人Token

# 主人的 Telegram 数字用户 ID
TG_OWNER_ID=6713156116

# 开启话题功能的超级群组 ID
TG_GROUP_ID=-100000000000

# 是否输出 Telegram 完整请求日志
TG_DEBUG=false

# Telegram 长轮询超时时间，单位秒
TG_POLL_TIMEOUT=60


# ==================== Telegram 代理 ====================

# 是否启用 Telegram 代理
TG_PROXY_ENABLED=false

# Telegram SOCKS5 代理地址
TG_PROXY_URL=socks5://127.0.0.1:50936

# PostgreSQL 数据库地址
POSTGRES_HOST=127.0.0.1

# PostgreSQL 数据库端口
POSTGRES_PORT=5432

# PostgreSQL 数据库用户名
POSTGRES_USER=postgres

# PostgreSQL 数据库密码
POSTGRES_PASSWORD=你的数据库密码

# PostgreSQL 数据库名称
POSTGRES_DB=shuangxiang

POSTGRES_SSLMODE=disable

# PostgreSQL 最大连接数
POSTGRES_MAX_CONNS=20

# PostgreSQL 最小连接数
POSTGRES_MIN_CONNS=2


# Redis 服务器地址和端口
REDIS_ADDR=127.0.0.1:6379

# Redis 用户名，没有可留空
REDIS_USERNAME=

# Redis 密码，没有可留空
REDIS_PASSWORD=

# Redis 数据库编号
REDIS_DB=10

# Redis 最大连接池数量
REDIS_POOL_SIZE=20
